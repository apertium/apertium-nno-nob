#!/usr/bin/jq -rMf

# $ find finn-relaterte-ord.nno/article -type f -print0 | xargs -0 ./json-paradigm-to-tsv >finn-relaterte-ord.nno/lemma-tag-paradigm.tsv

.lemmas
  | map(
      . as $lemma
      | .paradigm_info[]
      | {
          lemma: $lemma.lemma,
          id: $lemma.id,
          paradigm_id: .paradigm_id,
          tags: (.tags | join(".")),
          inflection_group: .inflection_group
        }
    )
  | .[]
  | [.lemma, (.tags | ascii_downcase), .paradigm_id, .id, .inflection_group]
  | @tsv
